# UI-first dev:
# Leave NEXT_PUBLIC_API_BASE_URL empty to use the built-in Next.js proxy route
# (recommended when accessing the UI via VM public IP).
#
# If you want the browser to call an API directly, set NEXT_PUBLIC_API_BASE_URL.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8081

# Server-side (Next.js) proxy target for the Prism mock server
MOCK_API_BASE_URL=http://127.0.0.1:8081
